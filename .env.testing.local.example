# Docker開発環境でテストを実行する場合の設定例
# このファイルを .env.testing.local にコピーして使用してください
# .env.testing.local は .gitignore に含まれているため、各開発者の環境に合わせてカスタマイズできます

# Docker環境用データベース設定
DB_HOST=db
DB_PORT=3306
DB_DATABASE=radio_review_test
DB_USERNAME=laravel
DB_PASSWORD=password

# Docker環境用Redis設定
REDIS_HOST=redis
REDIS_PORT=6379
